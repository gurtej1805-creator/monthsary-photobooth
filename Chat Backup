"use client";

import { useEffect, useRef, useState, useCallback } from "react";

// List of fun filters
const FILTERS = [
  { name: "Normal", filter: "" },
  { name: "Grayscale", filter: "grayscale(100%)" },
  { name: "Vintage Sepia", filter: "sepia(70%)" },
  { name: "Pop Art", filter: "contrast(150%) saturate(150%) hue-rotate(90deg)" },
  { name: "Soft Glow", filter: "brightness(110%) blur(1px)" },
];

export default function Photobooth() {
  const [peerId, setPeerId] = useState("");
  const [partnerId, setPartnerId] = useState("");
  const [peerInstance, setPeerInstance] = useState<any>(null);
  
  const [activeFilter, setActiveFilter] = useState(FILTERS[0]);
  const [sequenceStatus, setSequenceStatus] = useState({ isSequencing: false, count: 0, total: 3, currentText: "" });
  
  const localVideoRef = useRef<HTMLVideoElement>(null);
  const remoteVideoRef = useRef<HTMLVideoElement>(null);
  const canvasRef = useRef<HTMLCanvasElement>(null);

  // Initialize PeerJS and Local Camera (Same as before)
  useEffect(() => {
    import("peerjs").then(({ default: Peer }) => {
      const peer = new Peer();
      
      peer.on("open", (id) => {
        setPeerId(id);
      });

      navigator.mediaDevices.getUserMedia({ video: true, audio: false })
        .then((stream) => {
          if (localVideoRef.current) {
            localVideoRef.current.srcObject = stream;
          }

          peer.on("call", (call) => {
            call.answer(stream);
            call.on("stream", (remoteStream) => {
              if (remoteVideoRef.current) {
                remoteVideoRef.current.srcObject = remoteStream;
              }
            });
          });
        })
        .catch((err) => console.error("Failed to get local stream", err));

      setPeerInstance(peer);

      return () => {
        peer.destroy();
      };
    });
  }, []);

  const callPartner = () => {
    if (!peerInstance || !partnerId) return;

    navigator.mediaDevices.getUserMedia({ video: true, audio: false })
      .then((stream) => {
        const call = peerInstance.call(partnerId, stream);
        call.on("stream", (remoteStream) => {
          if (remoteVideoRef.current) {
            remoteVideoRef.current.srcObject = remoteStream;
          }
        });
      });
  };

  // Helper function to draw a single combined moment onto the canvas with filter
  const drawCombinedMoment = useCallback((ctx: CanvasRenderingContext2D, yOffset: number) => {
    const localVideo = localVideoRef.current;
    const remoteVideo = remoteVideoRef.current;
    if (!localVideo || !remoteVideo) return;

    // Apply the selected filter
    ctx.filter = activeFilter.filter;

    // Draw both video frames directly onto the canvas
    ctx.drawImage(localVideo, 0, yOffset, 640, 480);
    ctx.drawImage(remoteVideo, 640, yOffset, 640, 480);
    
    // Reset filter for other elements (like watermark)
    ctx.filter = ""; 
  }, [activeFilter]);

  // The major upgrade: Sequencing and Vertical Sticking
  const takePhotoStripSequence = async () => {
    const canvas = canvasRef.current;
    if (!canvas || sequenceStatus.isSequencing) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const numPhotos = 3;
    const individualWidth = 640;
    const individualHeight = 480;

    // Set canvas to be a TALL vertical strip: (Side + Side) x 3 captures tall
    canvas.width = individualWidth * 2; 
    canvas.height = individualHeight * numPhotos;

    // Clean canvas
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    setSequenceStatus(prev => ({ ...prev, isSequencing: true, currentText: `Get Ready! (Photo 1)` }));

    // Capture Loop
    for (let i = 0; i < numPhotos; i++) {
      // 3 second countdown for each photo
      for (let countdown = 3; countdown > 0; countdown--) {
        await new Promise(resolve => setTimeout(resolve, 1000));
        setSequenceStatus(prev => ({ ...prev, count: i + 1, currentText: `${countdown}...` }));
      }

      // Draw the single combined moment at the correct vertical position
      const yOffset = i * individualHeight;
      drawCombinedMoment(ctx, yOffset);
      
      // Update the main UI indicator
      setSequenceStatus(prev => ({ ...prev, currentText: `Snapped! Photo ${i+1}/${numPhotos}` }));
      
      // Add a visual flash
      const flash = document.createElement("div");
      flash.className = "fixed inset-0 bg-white z-[100] animate-[flash_0.2s_ease-out]";
      document.body.appendChild(flash);
      setTimeout(() => document.body.removeChild(flash), 200);

      // Short delay before the next countdown starts
      await new Promise(resolve => setTimeout(resolve, 1000));
    }

    // Final Step: Add Watermark at the bottom of the complete strip
    ctx.font = "bold 40px 'Arial Black', sans-serif";
    ctx.fillStyle = "white";
    ctx.textAlign = "center";
    ctx.shadowColor = "rgba(0, 0, 0, 0.7)";
    ctx.shadowBlur = 15;
    ctx.fillText(`Happy 1st Monthsary Season 2! 💖 Strip Filter: ${activeFilter.name}`, canvas.width / 2, canvas.height - 40);

    // Trigger the large strip image download
    const dataUrl = canvas.toDataURL("image/png");
    const link = document.createElement("a");
    link.download = `our-monthsary-photostrip-${activeFilter.name.toLowerCase()}.png`;
    link.href = dataUrl;
    link.click();
    
    // Complete sequence
    setSequenceStatus(prev => ({ ...prev, isSequencing: false, currentText: "Downloaded!" }));
  };

  return (
    <main className="flex min-h-screen flex-col items-center justify-center bg-gray-950 text-white p-5 overflow-x-hidden relative">
      
      {/* On-screen Countdown Text (Huge) */}
      {sequenceStatus.isSequencing && (
        <div className="fixed inset-0 z-[80] flex items-center justify-center pointer-events-none bg-black/70">
          <h2 className="text-[150px] font-extrabold text-white font-mono drop-shadow-[0_0_20px_rgba(255,255,255,0.7)] animate-pulse">
            {sequenceStatus.currentText}
          </h2>
        </div>
      )}

      <h1 className="text-5xl font-bold mb-10 text-pink-400 font-serif drop-shadow-[0_0_10px_rgba(236,72,153,0.5)]">Our Secret Photobooth Strip 📸</h1>
      
      <div className="flex flex-col md:flex-row gap-6 mb-10">
        <div className="flex flex-col items-center">
          <p className="mb-2 font-semibold text-gray-300">You</p>
          <video ref={localVideoRef} autoPlay playsInline muted className="w-[320px] h-[240px] bg-black rounded-3xl border-8 border-pink-500 object-cover shadow-[0_0_25px_rgba(236,72,153,0.7)] transform scale-x-[-1]" />
        </div>
        <div className="flex flex-col items-center">
          <p className="mb-2 font-semibold text-gray-300">Her</p>
          <video ref={remoteVideoRef} autoPlay playsInline className="w-[320px] h-[240px] bg-black rounded-3xl border-8 border-pink-500 object-cover shadow-[0_0_25px_rgba(236,72,153,0.7)] transform scale-x-[-1]" />
        </div>
      </div>

      <div className="bg-gray-900 p-8 rounded-3xl shadow-[0_0_40px_rgba(0,0,0,0.5)] flex flex-col items-center gap-6 w-full max-w-lg border border-gray-800">
        <p className="text-sm text-gray-400">Your Room ID: <span className="font-mono text-pink-400 bg-gray-950 px-3 py-1.5 rounded select-all shadow-inner">{peerId || "Generating..."}</span></p>
        
        <div className="flex gap-3 w-full">
          <input 
            type="text" 
            placeholder="Paste her Room ID here..." 
            className="flex-1 p-4 rounded-xl bg-gray-950 text-white border border-gray-700 focus:outline-none focus:border-pink-500 transition-colors shadow-inner"
            value={partnerId}
            onChange={(e) => setPartnerId(e.target.value)}
          />
          <button 
            onClick={callPartner}
            className="px-8 py-4 bg-pink-600 rounded-xl hover:bg-pink-500 font-bold transition-colors shadow-[0_4px_10px_rgba(219,39,119,0.4)]"
          >
            Connect
          </button>
        </div>

        {/* Filter Selection Panel */}
        <div className="w-full flex flex-col gap-2 mt-2">
            <p className="text-sm font-semibold text-gray-400">Select Strip Filter:</p>
            <div className="grid grid-cols-3 gap-2">
                {FILTERS.map(f => (
                    <button key={f.name} onClick={() => setActiveFilter(f)} className={`px-4 py-2 text-xs font-bold rounded-lg transition-all ${activeFilter.name === f.name ? 'bg-pink-500 text-white shadow-[0_0_10px_rgba(236,72,153,0.5)]' : 'bg-gray-800 text-gray-400 hover:bg-gray-700'}`}>
                        {f.name}
                    </button>
                ))}
            </div>
        </div>

        <button 
          onClick={takePhotoStripSequence}
          disabled={sequenceStatus.isSequencing}
          className="w-full mt-2 px-8 py-5 bg-white text-pink-600 rounded-2xl font-extrabold text-2xl hover:bg-pink-50 transition-all shadow-[0_0_30px_rgba(255,255,255,0.4)] hover:scale-[1.03] active:scale-[0.97] disabled:bg-gray-600 disabled:text-gray-400 disabled:scale-100 disabled:cursor-not-allowed"
        >
          {sequenceStatus.isSequencing ? "📸 Sequencer Running..." : "📸 Start Photobooth Strip Sequence!"}
        </button>
      </div>

      {/* Tailwind animation definition for flash */}
      <style>{`
        @keyframes flash {
          0% { opacity: 1; }
