"use client";

import { useEffect, useRef, useState } from "react";

export default function Photobooth() {
  const [peerId, setPeerId] = useState("");
  const [partnerId, setPartnerId] = useState("");
  const [peerInstance, setPeerInstance] = useState<any>(null);
  
  const localVideoRef = useRef<HTMLVideoElement>(null);
  const remoteVideoRef = useRef<HTMLVideoElement>(null);
  const canvasRef = useRef<HTMLCanvasElement>(null);

  useEffect(() => {
    // Dynamically import PeerJS so it doesn't break Next.js server-side rendering
    import("peerjs").then(({ default: Peer }) => {
      const peer = new Peer();
      
      peer.on("open", (id) => {
        setPeerId(id);
      });

      // Get local camera
      navigator.mediaDevices.getUserMedia({ video: true, audio: false })
        .then((stream) => {
          if (localVideoRef.current) {
            localVideoRef.current.srcObject = stream;
          }

          // Answer incoming connections automatically
          peer.on("call", (call) => {
            call.answer(stream);
            call.on("stream", (remoteStream) => {
              if (remoteVideoRef.current) {
                remoteVideoRef.current.srcObject = remoteStream;
              }
            });
          });
        })
        .catch((err) => console.error("Failed to get local stream", err));

      setPeerInstance(peer);

      return () => {
        peer.destroy();
      };
    });
  }, []);

  const callPartner = () => {
    if (!peerInstance || !partnerId) return;

    navigator.mediaDevices.getUserMedia({ video: true, audio: false })
      .then((stream) => {
        const call = peerInstance.call(partnerId, stream);
        call.on("stream", (remoteStream) => {
          if (remoteVideoRef.current) {
            remoteVideoRef.current.srcObject = remoteStream;
          }
        });
      });
  };

  const takePhoto = () => {
    const canvas = canvasRef.current;
    const localVideo = localVideoRef.current;
    const remoteVideo = remoteVideoRef.current;

    if (!canvas || !localVideo || !remoteVideo) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    // Set canvas to fit two 640x480 videos side-by-side
    canvas.width = 1280; 
    canvas.height = 480;

    // Draw both video frames directly onto the canvas
    ctx.drawImage(localVideo, 0, 0, 640, 480);
    ctx.drawImage(remoteVideo, 640, 0, 640, 480);

    // Add a cute watermark at the bottom center
    ctx.font = "bold 30px Arial";
    ctx.fillStyle = "white";
    ctx.textAlign = "center";
    ctx.shadowColor = "rgba(0, 0, 0, 0.7)";
    ctx.shadowBlur = 10;
    ctx.fillText("Happy 1st Monthsary Season 2! 💖", 640, 450);

    // Trigger the image download
    const dataUrl = canvas.toDataURL("image/png");
    const link = document.createElement("a");
    link.download = "our-monthsary-photo.png";
    link.href = dataUrl;
    link.click();
  };

  return (
    <main className="flex min-h-screen flex-col items-center justify-center bg-gray-900 text-white p-5">
      <h1 className="text-4xl font-bold mb-8 text-pink-400">Our Secret Photobooth 📸</h1>
      
      <div className="flex flex-col md:flex-row gap-4 mb-8">
        <div className="flex flex-col items-center">
          <p className="mb-2 font-semibold">You</p>
          <video ref={localVideoRef} autoPlay playsInline muted className="w-[320px] h-[240px] bg-black rounded-xl border-4 border-pink-500 object-cover shadow-[0_0_15px_rgba(236,72,153,0.5)] transform scale-x-[-1]" />
        </div>
        <div className="flex flex-col items-center">
          <p className="mb-2 font-semibold">Her</p>
          <video ref={remoteVideoRef} autoPlay playsInline className="w-[320px] h-[240px] bg-black rounded-xl border-4 border-pink-500 object-cover shadow-[0_0_15px_rgba(236,72,153,0.5)] transform scale-x-[-1]" />
        </div>
      </div>

      <div className="bg-gray-800 p-6 rounded-2xl shadow-xl flex flex-col items-center gap-4 w-full max-w-md border border-gray-700">
        <p className="text-sm text-gray-300">Your Room ID: <span className="font-mono text-pink-400 bg-gray-900 px-2 py-1 rounded select-all">{peerId || "Generating..."}</span></p>
        
        <div className="flex gap-2 w-full">
          <input 
            type="text" 
            placeholder="Paste her Room ID here..." 
            className="flex-1 p-3 rounded-lg bg-gray-900 text-white border border-gray-600 focus:outline-none focus:border-pink-500 transition-colors"
            value={partnerId}
            onChange={(e) => setPartnerId(e.target.value)}
          />
          <button 
            onClick={callPartner}
            className="px-6 py-3 bg-pink-600 rounded-lg hover:bg-pink-500 font-bold transition-colors shadow-lg"
          >
            Connect
          </button>
        </div>

        <button 
          onClick={takePhoto}
          className="w-full mt-2 px-6 py-4 bg-white text-pink-600 rounded-xl font-extrabold text-xl hover:bg-pink-50 transition-all shadow-[0_0_20px_rgba(255,255,255,0.3)] hover:scale-[1.02] active:scale-[0.98]"
        >
          📸 Snap Photo!
        </button>
      </div>

      {/* This canvas does the heavy lifting behind the scenes */}
      <canvas ref={canvasRef} className="hidden" />
    </main>
  );
}

