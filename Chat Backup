    link.download = `our-monthsary-photostrip-${activeFilter.name.toLowerCase().replace(' ', '-')}.png`;
    link.href = dataUrl;
    link.click();
    
    setSequenceStatus(prev => ({ ...prev, isSequencing: false, currentText: "Downloaded!" }));
  };

